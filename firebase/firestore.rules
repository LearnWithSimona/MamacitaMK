rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for scraped products; only the Admin SDK (Cloud Functions) writes.
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /scrape_runs/{runId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
